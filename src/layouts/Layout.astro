---
import BaseLayout from "./BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

type Props = {
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  keywords?: string[];
  type?: "website" | "article" | "profile";
  pubDate?: string | Date;
  updatedDate?: string | Date;
  tags?: string[];
  canonical?: string;
  noindex?: boolean;
  /**
   * Mark which top-level route is active for the nav.
   * One of: "home" | "writings" | "about" | "contact".
   */
  activeRoute?: string;
};

const { activeRoute, ...seoProps } = Astro.props;
---

<BaseLayout {...seoProps}>
  <div class="app">
    <Header activeRoute={activeRoute} />
    <main>
      <slot />
    </main>
    <Footer />
  </div>
</BaseLayout>
