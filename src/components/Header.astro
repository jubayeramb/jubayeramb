---
import Signature from "./Signature.astro";
import SearchTrigger from "./SearchTrigger.astro";

type Props = {
  activeRoute?: string;
};

const { activeRoute } = Astro.props;
const { pathname } = Astro.url;

const inferred = (() => {
  const seg = pathname.replace(/\/$/, "").split("/")[1];
  if (!seg) return "home";
  return seg;
})();

const active = activeRoute || inferred;

const NAV = [
  { id: "projects", label: "Projects", href: "/projects", priority: "primary", hint: "Selected case studies" },
  { id: "writings", label: "Writings", href: "/writings", priority: "primary", hint: "Notes on engineering and craft" },
  { id: "ask", label: "Ask", href: "/ask", priority: "primary", hint: "RAG chat grounded in this site" },
  { id: "about", label: "About", href: "/about", priority: "secondary", hint: "Background and approach" },
  { id: "contact", label: "Contact", href: "/contact", priority: "secondary", hint: "Get in touch" },
];
---

<nav class="nav">
  <a
    href="/"
    class="brand"
    aria-label="Jubayer Al Mamun, home"
  >
    <Signature />
  </a>
  <div class="nav-links">
    {
      NAV.map((item) => (
        <a
          href={item.href}
          class={`nav-link nav-link--${item.priority} ${active === item.id ? "active" : ""}`}
        >
          {item.label}
        </a>
      ))
    }
    <SearchTrigger />
    <button
      id="navMenuToggle"
      class="nav-toggle"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="navMobileMenu"
      type="button"
    >
      <span class="nav-toggle-icon" aria-hidden="true">
        <span class="nav-toggle-line nav-toggle-line--top"></span>
        <span class="nav-toggle-line nav-toggle-line--bot"></span>
      </span>
    </button>
    <button
      id="themeToggle"
      class="theme-toggle"
      aria-label="Toggle color theme"
      type="button"
    >
      <svg
        id="themeIconSun"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <circle cx="12" cy="12" r="4"></circle>
        <path
          d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
        ></path>
      </svg>
      <svg
        id="themeIconMoon"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        style="display:none"
      >
        <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
      </svg>
    </button>
  </div>
</nav>

<div
  id="navMobileMenu"
  class="nav-sheet"
  role="dialog"
  aria-modal="true"
  aria-labelledby="navMenuToggle"
  data-state="closed"
  hidden
>
  <div class="nav-sheet-inner">
    <div class="nav-sheet-eyebrow" aria-hidden="true">Navigation</div>
    <ul class="nav-sheet-list">
      {
        NAV.map((item, i) => (
          <li
            class="nav-sheet-item"
            style={`--i:${i};`}
          >
            <a
              href={item.href}
              class={`nav-sheet-link ${active === item.id ? "active" : ""}`}
            >
              <span class="nav-sheet-num">
                {String(i + 1).padStart(2, "0")}
              </span>
              <span class="nav-sheet-text">
                <span class="nav-sheet-label">{item.label}</span>
                <span class="nav-sheet-hint">{item.hint}</span>
              </span>
              <svg
                class="nav-sheet-arrow"
                viewBox="0 0 24 24"
                width="16"
                height="16"
                fill="none"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M5 12h14M13 6l6 6-6 6" />
              </svg>
            </a>
          </li>
        ))
      }
    </ul>
    <div class="nav-sheet-footer">
      <span class="nav-sheet-footer-pulse" aria-hidden="true" />
      <span>jubayeramb.com</span>
      <span class="nav-sheet-footer-sep" aria-hidden="true">·</span>
      <span>Dhaka, UTC+6</span>
    </div>
  </div>
</div>

<script>
  const syncIcon = () => {
    const theme = document.documentElement.getAttribute("data-theme") || "light";
    const sun = document.getElementById("themeIconSun") as HTMLElement | null;
    const moon = document.getElementById("themeIconMoon") as HTMLElement | null;
    if (!sun || !moon) return;
    if (theme === "dark") {
      sun.style.display = "block";
      moon.style.display = "none";
    } else {
      sun.style.display = "none";
      moon.style.display = "block";
    }
  };

  const handleToggle = () => {
    const current =
      document.documentElement.getAttribute("data-theme") || "light";
    const next = current === "dark" ? "light" : "dark";
    document.documentElement.setAttribute("data-theme", next);
    try {
      localStorage.setItem("theme", next);
    } catch (e) {}
    syncIcon();
  };

  const wire = () => {
    syncIcon();
    const btn = document.getElementById("themeToggle");
    if (btn && !(btn as any).__wired) {
      btn.addEventListener("click", handleToggle);
      (btn as any).__wired = true;
    }
  };

  const wireMenu = () => {
    const toggle = document.getElementById("navMenuToggle");
    const menu = document.getElementById("navMobileMenu");
    if (!toggle || !menu || (toggle as any).__wired) return;
    (toggle as any).__wired = true;

    // CSS exit animation length — sheet & links fade/scale down before
    // we flip `hidden`. Keep in sync with the .nav-sheet[data-state]
    // keyframes in global.css.
    const EXIT_MS = 240;
    let exitTimer = 0;

    const setOpen = (open: boolean) => {
      toggle.setAttribute("aria-expanded", String(open));
      toggle.setAttribute(
        "aria-label",
        open ? "Close menu" : "Open menu",
      );
      if (exitTimer) {
        clearTimeout(exitTimer);
        exitTimer = 0;
      }
      if (open) {
        menu.hidden = false;
        // Two-step: paint hidden=false first, then flip data-state on
        // the next frame so the enter animation actually runs (rather
        // than the browser collapsing it because we transitioned from
        // display:none → flex in the same frame).
        requestAnimationFrame(() => {
          menu.dataset.state = "open";
        });
        document.documentElement.style.overflow = "hidden";
        document.body.style.overflow = "hidden";
        // Move focus into the sheet so screen readers & keyboard users
        // land on the first nav link.
        const first = menu.querySelector<HTMLElement>(".nav-sheet-link");
        first?.focus({ preventScroll: true });
      } else {
        menu.dataset.state = "closed";
        document.documentElement.style.overflow = "";
        document.body.style.overflow = "";
        exitTimer = window.setTimeout(() => {
          menu.hidden = true;
          exitTimer = 0;
          // Return focus to the toggle if it's still in the DOM.
          if (document.body.contains(toggle)) {
            (toggle as HTMLElement).focus({ preventScroll: true });
          }
        }, EXIT_MS);
      }
    };

    toggle.addEventListener("click", (e) => {
      e.stopPropagation();
      const isOpen = toggle.getAttribute("aria-expanded") === "true";
      setOpen(!isOpen);
    });

    // Click outside the inner card (i.e. on the backdrop) closes.
    menu.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;
      const a = target.closest("a");
      if (a) {
        setOpen(false);
        return;
      }
      // The dialog itself is the backdrop; clicks on `.nav-sheet-inner`
      // shouldn't bubble down to it.
      if (target === menu) setOpen(false);
    });

    document.addEventListener("keydown", (e) => {
      if (menu.hidden) return;
      if (e.key === "Escape") {
        setOpen(false);
        return;
      }
      // Simple focus trap — when tabbing past the last link, wrap to
      // the first, and shift-tabbing past the first wraps to the last.
      if (e.key === "Tab") {
        const focusables = menu.querySelectorAll<HTMLElement>(
          "a, button, [tabindex]:not([tabindex='-1'])",
        );
        if (!focusables.length) return;
        const first = focusables[0];
        const last = focusables[focusables.length - 1];
        const activeEl = document.activeElement;
        if (e.shiftKey && activeEl === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && activeEl === last) {
          e.preventDefault();
          first.focus();
        }
      }
    });

    // Astro page transitions can swap pages while the sheet is open
    // (e.g. clicking a nav link). Reset scroll lock + state so the new
    // page isn't stuck behind a hidden=true menu with overflow locked.
    document.addEventListener(
      "astro:before-swap",
      () => {
        document.documentElement.style.overflow = "";
        document.body.style.overflow = "";
        menu.dataset.state = "closed";
        menu.hidden = true;
        toggle.setAttribute("aria-expanded", "false");
        toggle.setAttribute("aria-label", "Open menu");
        if (exitTimer) {
          clearTimeout(exitTimer);
          exitTimer = 0;
        }
      },
      { once: true },
    );
  };

  wire();
  wireMenu();
  document.addEventListener("astro:page-load", () => {
    wire();
    wireMenu();
  });
  document.addEventListener("astro:after-swap", syncIcon);
</script>
