---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  image?: string;
  keywords?: string[];
}

const {
  title = "Jubayer Al Mamun",
  description = "Software Engineer building things for the web — based in Dhaka, Bangladesh.",
  image = "https://jubayeramb.github.io/assets/images/og-image.png",
  keywords,
} = Astro.props;

const keywords_ =
  keywords && keywords.length > 0 ? keywords.join(", ") + ", " : "";

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="author" content="Jubayer Al Mamun" />
    <meta
      name="keywords"
      content={keywords_ +
        "Jubayer Al Mamun, software engineer, web developer, full stack developer, JavaScript, TypeScript, React, Next.js, Astro, Node.js, blog, portfolio"}
    />

    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <meta property="og:image" content={image} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Jubayer Al Mamun" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://jubayeramb.github.io/" />
    <meta property="og:type" content="website" />
    <meta name="generator" content={Astro.generator} />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta name="twitter:creator" content="@jubayeramb" />
    <meta name="twitter:image" content={image} />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />

    <link
      rel="alternate"
      href="/rss.xml"
      type="application/rss+xml"
      title={title}
    />

    <script is:inline>
      (function () {
        function applyTheme() {
          try {
            var stored = localStorage.getItem("theme");
            var prefersDark = window.matchMedia(
              "(prefers-color-scheme: dark)"
            ).matches;
            var theme = stored || (prefersDark ? "dark" : "light");
            document.documentElement.setAttribute("data-theme", theme);
          } catch (e) {}
        }
        applyTheme();
        document.addEventListener("astro:after-swap", applyTheme);
      })();
    </script>

    <ClientRouter />
  </head>
  <body>
    <slot />
  </body>
</html>
