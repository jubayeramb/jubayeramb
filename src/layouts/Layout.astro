---
import BaseLayout from "./BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

type CollectionItem = {
  title: string;
  url: string;
  date?: string | Date;
  description?: string;
};

type ProjectMeta = {
  role?: string;
  period?: string;
  url?: string;
  technologies?: string[];
  softwareApp?: {
    applicationCategory: string;
    operatingSystem: string;
    price?: string;
    priceCurrency?: string;
  };
};

type Props = {
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  keywords?: string[];
  type?: "website" | "article" | "profile" | "project";
  pubDate?: string | Date;
  updatedDate?: string | Date;
  tags?: string[];
  projectMeta?: ProjectMeta;
  collectionItems?: CollectionItem[];
  collectionKind?: "Article" | "CreativeWork" | "WebPage";
  profilePage?: boolean;
  canonical?: string;
  noindex?: boolean;
  /**
   * Mark which top-level route is active for the nav.
   * One of: "home" | "now" | "projects" | "writings" | "ask" | "about" | "contact".
   */
  activeRoute?: string;
};

const { activeRoute, ...seoProps } = Astro.props;
---

<BaseLayout {...seoProps}>
  <div class="app">
    <Header activeRoute={activeRoute} />
    <main>
      <slot />
    </main>
    <Footer />
  </div>
</BaseLayout>
