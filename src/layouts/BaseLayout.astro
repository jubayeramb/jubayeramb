---
import { ClientRouter } from "astro:transitions";
import Seo from "@/components/Seo.astro";
import CommandPalette from "@/components/CommandPalette.astro";
import "../styles/global.css";

type CollectionItem = {
  title: string;
  url: string;
  date?: string | Date;
  description?: string;
};

type ProjectMeta = {
  role?: string;
  period?: string;
  url?: string;
  technologies?: string[];
};

interface Props {
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  keywords?: string[];
  type?: "website" | "article" | "profile" | "project";
  pubDate?: string | Date;
  updatedDate?: string | Date;
  tags?: string[];
  projectMeta?: ProjectMeta;
  collectionItems?: CollectionItem[];
  collectionKind?: "Article" | "CreativeWork" | "WebPage";
  profilePage?: boolean;
  canonical?: string;
  noindex?: boolean;
}

const {
  title = "Jubayer Al Mamun",
  description,
  image,
  imageAlt,
  keywords,
  type,
  pubDate,
  updatedDate,
  tags,
  projectMeta,
  collectionItems,
  collectionKind,
  profilePage,
  canonical,
  noindex,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <Seo
      {title}
      {description}
      {image}
      {imageAlt}
      {keywords}
      {type}
      {pubDate}
      {updatedDate}
      {tags}
      {projectMeta}
      {collectionItems}
      {collectionKind}
      {profilePage}
      {canonical}
      {noindex}
    />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <script is:inline>
      (function () {
        function applyTheme() {
          try {
            var stored = localStorage.getItem("theme");
            var prefersDark = window.matchMedia(
              "(prefers-color-scheme: dark)"
            ).matches;
            var theme = stored || (prefersDark ? "dark" : "light");
            document.documentElement.setAttribute("data-theme", theme);
          } catch (e) {}
        }
        applyTheme();
        document.addEventListener("astro:after-swap", applyTheme);
      })();
    </script>

    <ClientRouter />
  </head>
  <body>
    <slot />
    <CommandPalette />
  </body>
</html>
