---
import Signature from "./Signature.astro";
import SearchTrigger from "./SearchTrigger.astro";

type Props = {
  activeRoute?: string;
};

const { activeRoute } = Astro.props;
const { pathname } = Astro.url;

const inferred = (() => {
  const seg = pathname.replace(/\/$/, "").split("/")[1];
  if (!seg) return "home";
  return seg;
})();

const active = activeRoute || inferred;

const NAV = [
  { id: "projects", label: "Projects", href: "/projects", priority: "primary" },
  { id: "writings", label: "Writings", href: "/writings", priority: "primary" },
  { id: "ask", label: "Ask", href: "/ask", priority: "primary" },
  { id: "about", label: "About", href: "/about", priority: "secondary" },
  { id: "contact", label: "Contact", href: "/contact", priority: "secondary" },
];
---

<nav class="nav">
  <a
    href="/"
    class="brand"
    aria-label="Jubayer Al Mamun, home"
  >
    <Signature />
  </a>
  <div class="nav-links">
    {
      NAV.map((item) => (
        <a
          href={item.href}
          class={`nav-link nav-link--${item.priority} ${active === item.id ? "active" : ""}`}
        >
          {item.label}
        </a>
      ))
    }
    <SearchTrigger />
    <button
      id="navMenuToggle"
      class="nav-hamburger"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="navMobileMenu"
      type="button"
    >
      <svg
        viewBox="0 0 24 24"
        width="14"
        height="14"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <path d="M4 7h16M4 12h16M4 17h16"></path>
      </svg>
    </button>
    <button
      id="themeToggle"
      class="theme-toggle"
      aria-label="Toggle color theme"
      type="button"
    >
      <svg
        id="themeIconSun"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <circle cx="12" cy="12" r="4"></circle>
        <path
          d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
        ></path>
      </svg>
      <svg
        id="themeIconMoon"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        style="display:none"
      >
        <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
      </svg>
    </button>
  </div>
</nav>

<div
  id="navMobileMenu"
  class="nav-mobile-menu"
  role="menu"
  aria-labelledby="navMenuToggle"
  hidden
>
  {
    NAV.map((item) => (
      <a
        href={item.href}
        role="menuitem"
        class={`nav-mobile-link ${active === item.id ? "active" : ""}`}
      >
        {item.label}
      </a>
    ))
  }
</div>

<script>
  const syncIcon = () => {
    const theme = document.documentElement.getAttribute("data-theme") || "light";
    const sun = document.getElementById("themeIconSun") as HTMLElement | null;
    const moon = document.getElementById("themeIconMoon") as HTMLElement | null;
    if (!sun || !moon) return;
    if (theme === "dark") {
      sun.style.display = "block";
      moon.style.display = "none";
    } else {
      sun.style.display = "none";
      moon.style.display = "block";
    }
  };

  const handleToggle = () => {
    const current =
      document.documentElement.getAttribute("data-theme") || "light";
    const next = current === "dark" ? "light" : "dark";
    document.documentElement.setAttribute("data-theme", next);
    try {
      localStorage.setItem("theme", next);
    } catch (e) {}
    syncIcon();
  };

  const wire = () => {
    syncIcon();
    const btn = document.getElementById("themeToggle");
    if (btn && !(btn as any).__wired) {
      btn.addEventListener("click", handleToggle);
      (btn as any).__wired = true;
    }
  };

  const wireMenu = () => {
    const toggle = document.getElementById("navMenuToggle");
    const menu = document.getElementById("navMobileMenu");
    if (!toggle || !menu || (toggle as any).__wired) return;
    (toggle as any).__wired = true;

    const setOpen = (open: boolean) => {
      toggle.setAttribute("aria-expanded", String(open));
      menu.hidden = !open;
      if (open) document.documentElement.style.overflow = "hidden";
      else document.documentElement.style.overflow = "";
    };

    toggle.addEventListener("click", (e) => {
      e.stopPropagation();
      const isOpen = toggle.getAttribute("aria-expanded") === "true";
      setOpen(!isOpen);
    });

    document.addEventListener("click", (e) => {
      if (menu.hidden) return;
      const target = e.target as Node;
      if (menu.contains(target) || toggle.contains(target)) return;
      setOpen(false);
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !menu.hidden) setOpen(false);
    });

    menu.addEventListener("click", (e) => {
      const a = (e.target as HTMLElement)?.closest("a");
      if (a) setOpen(false);
    });
  };

  wire();
  wireMenu();
  document.addEventListener("astro:page-load", () => {
    wire();
    wireMenu();
  });
  document.addEventListener("astro:after-swap", syncIcon);
</script>
