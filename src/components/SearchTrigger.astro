---
// Renders the navbar's visible search affordance. Click → palette:open.
---

<button
  type="button"
  class="search-trigger"
  id="search-trigger"
  aria-label="Search"
>
  <svg
    viewBox="0 0 24 24"
    width="13"
    height="13"
    fill="none"
    stroke="currentColor"
    stroke-width="1.8"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="11" cy="11" r="7"></circle>
    <path d="m20 20-3.5-3.5"></path>
  </svg>
  <span class="search-trigger-label">Search</span>
  <kbd class="search-trigger-kbd">⌘K</kbd>
</button>

<script>
  const wireSearchTrigger = () => {
    const btn = document.getElementById("search-trigger");
    if (!btn || (btn as any).__wired) return;
    (btn as any).__wired = true;
    btn.addEventListener("click", () => {
      window.dispatchEvent(new CustomEvent("palette:open"));
    });
  };
  wireSearchTrigger();
  document.addEventListener("astro:page-load", wireSearchTrigger);
</script>

<style>
  .search-trigger {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 8px 6px 10px;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--fg-3);
    font-size: 12.5px;
    background: color-mix(in oklab, var(--bg), var(--fg) 1%);
    transition: color 0.2s, border-color 0.2s, background 0.2s;
    cursor: pointer;
    line-height: 1;
  }
  .search-trigger:hover {
    color: var(--fg);
    border-color: var(--line-2);
  }
  .search-trigger svg { flex-shrink: 0; }
  .search-trigger-label { font-family: var(--font-sans); }
  .search-trigger-kbd {
    font-family: var(--font-mono);
    font-size: 10px;
    padding: 2px 6px;
    border-radius: 4px;
    background: var(--line);
    color: var(--fg-2);
    letter-spacing: 0.04em;
  }
  @media (max-width: 720px) {
    .search-trigger {
      padding: 6px;
      gap: 0;
      width: 28px;
      height: 28px;
      justify-content: center;
    }
    .search-trigger-label,
    .search-trigger-kbd { display: none; }
  }
</style>
