---
const year = new Date().getFullYear();
const updated = new Date().toLocaleString("en-US", {
  month: "short",
  year: "numeric",
});
---

<footer class="footer">
  <div>© {year} Jubayer Al Mamun</div>
  <div>
    <a href="/rss.xml" aria-label="RSS feed">RSS</a>
    <span style="margin: 0 8px; color: var(--line-2);">·</span>
    Updated · {updated}
  </div>
</footer>
