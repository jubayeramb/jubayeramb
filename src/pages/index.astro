---
import Layout from "@/layouts/Layout.astro";
import FadeUp from "@/components/FadeUp.astro";
import HomeChatInput from "@/components/HomeChatInput.astro";
import ChatOverlay from "@/components/ChatOverlay.astro";
import { getCollection } from "astro:content";
import { getFullDate } from "@/utils";

const isProd = import.meta.env.PROD;

const posts = await getCollection("posts");
const sortedPosts = posts.sort((a, b) => {
  return (
    new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
  );
});
const recent = sortedPosts.slice(0, 3);

const selectedWork = (await getCollection("projects"))
  .filter((p) => (isProd ? !p.data.draft : true))
  .sort((a, b) => b.data.order - a.data.order)
  .slice(0, 3);
---

<Layout
  title="Jubayer Al Mamun"
  description="Jubayer Al Mamun is a software engineer based in Dhaka, Bangladesh. Building things for the web. Currently at WeCycle. Writing about TypeScript, React, and Astro."
  type="profile"
  activeRoute="home"
>
  <div class="page page--with-floating-chat">
    <FadeUp>
      <h1 class="h1">
        Hi, I'm Jubayer, a software engineer building things for the <em
          >web</em
        >.
      </h1>
    </FadeUp>

    <FadeUp delay={80}>
      <div class="home-intro">
        <p class="lead">
          I've spent the last few years shipping production software end to
          end, from <strong>Postgres schemas</strong> to <strong
            >pixel-tight UI</strong
          >. I care about well-considered interfaces, fast systems, and code
          that ages well.
        </p>
        <p class="lead">
          Currently a Software Engineer at <a
            href="https://getwecycle.com/"
            target="_blank"
            rel="noopener"
            style="color: var(--fg); border-bottom: 1px solid var(--line-2);"
            >WeCycle</a
          >, working on web and mobile products. CS graduate, mostly
          self-taught, still learning in public.
        </p>
      </div>
    </FadeUp>

    <FadeUp delay={140}>
      <div class="home-meta">
        <span class="avail">Open to freelance work</span>
        <span>Dhaka, Bangladesh</span>
        <span>UTC+6</span>
      </div>
    </FadeUp>

    <section class="section">
      <FadeUp>
        <div class="section-label">Recent writing</div>
      </FadeUp>
      <div class="list">
        {
          recent.map((post, i) => (
            <FadeUp
              delay={i * 40}
              as="a"
              class="list-item"
              href={`/writings/${post.id}`}
            >
              <div class="list-title" transition:name={`post-${post.id}`}>
                {post.data.title}
              </div>
              <div class="list-meta">{getFullDate(post.data.pubDate)}</div>
            </FadeUp>
          ))
        }
      </div>
      <FadeUp delay={200}>
        <div
          style="margin-top: 16px; font-family: var(--font-mono); font-size: 12px;"
        >
          <a
            href="/writings"
            style="color: var(--fg-3); border-bottom: 1px solid var(--line-2); padding-bottom: 1px;"
            >All writing →</a
          >
        </div>
      </FadeUp>
    </section>

    {
      selectedWork.length > 0 && (
        <section class="section">
          <FadeUp>
            <div class="section-label">Selected work</div>
          </FadeUp>
          <div class="list">
            {selectedWork.map((project, i) => (
              <FadeUp
                delay={i * 40}
                as="a"
                class="list-item"
                href={`/projects/${project.id}`}
              >
                <div>
                  <div
                    class="list-title"
                    transition:name={`project-${project.id}`}
                  >
                    {project.data.title}
                  </div>
                  <div class="list-desc">{project.data.summary}</div>
                </div>
                <div class="list-meta">{project.data.period}</div>
              </FadeUp>
            ))}
          </div>
          <FadeUp delay={200}>
            <div
              style="margin-top: 16px; font-family: var(--font-mono); font-size: 12px;"
            >
              <a
                href="/projects"
                style="color: var(--fg-3); border-bottom: 1px solid var(--line-2); padding-bottom: 1px;"
                >All projects →</a
              >
            </div>
          </FadeUp>
        </section>
      )
    }

    <section class="section">
      <FadeUp>
        <div class="section-label">Elsewhere</div>
      </FadeUp>
      <FadeUp delay={60}>
        <div class="tag-cloud">
          <a href="https://github.com/jubayeramb" target="_blank" rel="noopener"
            >GitHub ↗</a
          >
          <a
            href="https://www.linkedin.com/in/jubayeramb/"
            target="_blank"
            rel="noopener">LinkedIn ↗</a
          >
          <a
            href="https://twitter.com/jubayeramb"
            target="_blank"
            rel="noopener">X (Twitter) ↗</a
          >
          <a href="mailto:jubayeramb@gmail.com">Email ↗</a>
        </div>
      </FadeUp>
    </section>
  </div>
  <HomeChatInput />
  <ChatOverlay />
</Layout>

<style>
  .page--with-floating-chat {
    padding-bottom: 140px;
  }
  @media (max-width: 480px) {
    .page--with-floating-chat { padding-bottom: 110px; }
  }
</style>
