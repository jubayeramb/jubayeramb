---
import BaseLayout from "./BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

type Props = {
  title: string;
  description?: string;
  image?: string;
  keywords?: string[];
  /**
   * Mark which top-level route is active for the nav.
   * One of: "home" | "writings" | "about" | "contact".
   */
  activeRoute?: string;
};

const { title, description, image, keywords, activeRoute } = Astro.props;
---

<BaseLayout {title} {description} {image} {keywords}>
  <div class="app">
    <Header activeRoute={activeRoute} />
    <main>
      <slot />
    </main>
    <Footer />
  </div>
</BaseLayout>
