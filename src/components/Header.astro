---
type Props = {
  activeRoute?: string;
};

const { activeRoute } = Astro.props;
const { pathname } = Astro.url;

const inferred = (() => {
  const seg = pathname.replace(/\/$/, "").split("/")[1];
  if (!seg) return "home";
  return seg;
})();

const active = activeRoute || inferred;

const NAV = [
  { id: "writings", label: "Writings", href: "/writings" },
  { id: "about", label: "About", href: "/about" },
  { id: "contact", label: "Contact", href: "/contact" },
];
---

<nav class="nav">
  <a href="/" class="brand" aria-label="Jubayer Al Mamun, home">
    <span class="brand-mark">J</span>
    <span>Jubayer Al Mamun</span>
  </a>
  <div class="nav-links">
    {
      NAV.map((item) => (
        <a
          href={item.href}
          class={`nav-link ${active === item.id ? "active" : ""}`}
        >
          {item.label}
        </a>
      ))
    }
    <button
      id="themeToggle"
      class="theme-toggle"
      aria-label="Toggle color theme"
      type="button"
    >
      <svg
        id="themeIconSun"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <circle cx="12" cy="12" r="4"></circle>
        <path
          d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
        ></path>
      </svg>
      <svg
        id="themeIconMoon"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        style="display:none"
      >
        <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
      </svg>
    </button>
  </div>
</nav>

<script>
  const syncIcon = () => {
    const theme = document.documentElement.getAttribute("data-theme") || "light";
    const sun = document.getElementById("themeIconSun") as HTMLElement | null;
    const moon = document.getElementById("themeIconMoon") as HTMLElement | null;
    if (!sun || !moon) return;
    if (theme === "dark") {
      sun.style.display = "block";
      moon.style.display = "none";
    } else {
      sun.style.display = "none";
      moon.style.display = "block";
    }
  };

  const handleToggle = () => {
    const current =
      document.documentElement.getAttribute("data-theme") || "light";
    const next = current === "dark" ? "light" : "dark";
    document.documentElement.setAttribute("data-theme", next);
    try {
      localStorage.setItem("theme", next);
    } catch (e) {}
    syncIcon();
  };

  const wire = () => {
    syncIcon();
    const btn = document.getElementById("themeToggle");
    if (btn && !(btn as any).__wired) {
      btn.addEventListener("click", handleToggle);
      (btn as any).__wired = true;
    }
  };

  wire();
  document.addEventListener("astro:page-load", wire);
  document.addEventListener("astro:after-swap", syncIcon);
</script>
