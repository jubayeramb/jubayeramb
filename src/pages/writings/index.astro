---
import Layout from "@/layouts/Layout.astro";
import FadeUp from "@/components/FadeUp.astro";
import { getFullDate } from "@/utils";
import { getCollection } from "astro:content";

const posts = await getCollection("posts");
const sortedPosts = posts.sort((a, b) => {
  return (
    new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
  );
});

type Group = { year: string; items: typeof sortedPosts };
const grouped: Group[] = [];
for (const p of sortedPosts) {
  const year = String(new Date(p.data.pubDate).getFullYear());
  let group = grouped.find((g) => g.year === year);
  if (!group) {
    group = { year, items: [] };
    grouped.push(group);
  }
  group.items.push(p);
}

const title = "Writing";
const description =
  "Notes on JavaScript, TypeScript, Astro, web development, and the occasional reflection by Jubayer Al Mamun.";

const collectionItems = sortedPosts.map((p) => ({
  title: p.data.title,
  url: `/writings/${p.id}/`,
  date: p.data.pubDate,
  description: p.data.description,
}));
---

<Layout
  {title}
  {description}
  activeRoute="writings"
  collectionItems={collectionItems}
  collectionKind="Article"
>
  <div class="page">
    <FadeUp>
      <h1 class="h1">Writing</h1>
    </FadeUp>
    <FadeUp delay={60}>
      <p class="lead">
        Notes on tech, personal growth, life experiences, and the occasional
        reflection. I write about things I'm learning, hoping that it helps
        someone else on a similar path.
      </p>
    </FadeUp>

    <section class="section">
      {
        grouped.map((g, gi) => (
          <div>
            <FadeUp delay={gi * 60}>
              <div class="write-year">{g.year}</div>
            </FadeUp>
            <div class="list">
              {g.items.map((post, i) => (
                <FadeUp
                  delay={gi * 60 + i * 30}
                  as="a"
                  class="list-item"
                  href={`/writings/${post.id}`}
                >
                  <div class="list-title" transition:name={`post-${post.id}`}>
                    {post.data.title}
                  </div>
                  <div class="list-meta">{getFullDate(post.data.pubDate)}</div>
                </FadeUp>
              ))}
            </div>
          </div>
        ))
      }
    </section>
  </div>
</Layout>
