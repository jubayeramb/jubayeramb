---
import Layout from "./Layout.astro";
import FadeUp from "@/components/FadeUp.astro";
import type { BlogPostType } from "@/types";
import { generateOgImage, getFullDate } from "@/utils";

type Props = { postData: BlogPostType };

const {
  postData: { data: frontmatter, body },
} = Astro.props;

const { title, description, pubDate, updatedDate, tags, image } = frontmatter;

const wordCount = (body ?? "").split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 220));

const ogImage = `https://dynamic-og-image-generator.vercel.app/api/generate?${generateOgImage(
  title
)}`;
---

<Layout
  {title}
  {description}
  image={image?.url || ogImage}
  imageAlt={image?.alt || title}
  type="article"
  {pubDate}
  {updatedDate}
  {tags}
  activeRoute="writings"
>
  <article class="page">
    <FadeUp>
      <div style="margin-bottom: 24px;">
        <a
          href="/writings"
          style="font-family: var(--font-mono); font-size: 12px; color: var(--fg-3); border-bottom: 1px solid var(--line-2); padding-bottom: 1px;"
          >← All writing</a
        >
      </div>
    </FadeUp>

    <FadeUp delay={40}>
      <h1 class="h1" style="margin-bottom: 12px;">{title}</h1>
    </FadeUp>

    <FadeUp delay={80}>
      <div
        style="display: flex; flex-wrap: wrap; gap: 14px; font-family: var(--font-mono); font-size: 12px; color: var(--fg-3); margin-bottom: 28px;"
      >
        <time datetime={pubDate.toString()}
          >{getFullDate(pubDate.toString())}</time
        >
        <span>·</span>
        <span>{readingTime} min read</span>
        {
          tags && tags.length > 0 && (
            <>
              <span>·</span>
              <div style="display: flex; flex-wrap: wrap; gap: 8px;">
                {tags.map((tag) => (
                  <a href={`/tags/${tag}`} style="color: var(--fg-3);">
                    #{tag}
                  </a>
                ))}
              </div>
            </>
          )
        }
      </div>
    </FadeUp>

    {
      image?.url && (
        <FadeUp delay={120}>
          <figure style="margin-bottom: 32px;">
            <img
              src={image.url}
              alt={image.alt || "Cover image"}
              style="width: 100%; aspect-ratio: 16 / 9; object-fit: cover; border-radius: 8px; border: 1px solid var(--line);"
              loading="eager"
            />
          </figure>
        </FadeUp>
      )
    }

    <FadeUp delay={160}>
      <div id="article-content" class="blog-content">
        <slot />
      </div>
    </FadeUp>
  </article>
</Layout>

<script>
  const enhanceCodeBlocks = () => {
    const preElements = document.querySelectorAll<HTMLPreElement>(
      "#article-content pre"
    );
    preElements.forEach((preElement, idx) => {
      if (preElement.parentElement?.classList.contains("code-block")) return;

      const wrap = document.createElement("div");
      wrap.classList.add("code-block");
      preElement.parentNode?.insertBefore(wrap, preElement);

      const button = document.createElement("button");
      button.textContent = "Copy";
      button.classList.add("copy-button");
      button.type = "button";

      const span = document.createElement("span");
      span.textContent = "Copied!";
      span.classList.add("copied", "hidden");
      span.id = `copied-${idx}`;

      button.addEventListener("click", () => {
        navigator.clipboard.writeText(preElement.textContent || "");
        document.getElementById(`copied-${idx}`)?.classList.remove("hidden");
        setTimeout(
          () => document.getElementById(`copied-${idx}`)?.classList.add("hidden"),
          1500
        );
      });

      wrap.appendChild(preElement);
      wrap.appendChild(button);
      wrap.appendChild(span);
    });
  };

  enhanceCodeBlocks();
  document.addEventListener("astro:page-load", enhanceCodeBlocks);
</script>
