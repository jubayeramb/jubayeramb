---
import Layout from "@/layouts/Layout.astro";
import FadeUp from "@/components/FadeUp.astro";
import { getAllUniqueTags } from "@/utils";
import { getCollection } from "astro:content";

const allPosts = await getCollection("posts");
const tags = getAllUniqueTags(allPosts).sort();

const title = "Tags";
const description =
  "Browse Jubayer Al Mamun's writing by topic: JavaScript, TypeScript, Astro, CSS, and more.";

const collectionItems = tags.map((tag) => ({
  title: `#${tag}`,
  url: `/tags/${tag}/`,
}));
---

<Layout
  {title}
  {description}
  activeRoute="writings"
  collectionItems={collectionItems}
  collectionKind="WebPage"
>
  <div class="page">
    <FadeUp>
      <h1 class="h1">Tags</h1>
    </FadeUp>
    <FadeUp delay={60}>
      <p class="lead">
        Browse writing by topic. {tags.length}
        {tags.length === 1 ? "tag" : "tags"} in total.
      </p>
    </FadeUp>

    <section class="section">
      <FadeUp>
        <div class="tag-cloud">
          {tags.map((tag) => <a href={`/tags/${tag}`}>#{tag}</a>)}
        </div>
      </FadeUp>
    </section>
  </div>
</Layout>
