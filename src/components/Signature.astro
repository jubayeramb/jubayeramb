28 282.24 106.32Q281.64 108.36 281.22 110.22Q280.80 112.08 280.80 112.44Q280.80 112.44 280.44 113.58Q280.08 114.72 279.24 115.80Q277.80 117.72 276.84 117.72Q275.88 117.72 273.96 115.80";

const VIEWBOX = "-9 33 327 115";
const subpaths = PATH.split(/(?=M)/).filter(Boolean);

// Group subpaths into letters of "Jubayer" (7 glyphs). Letters with inner
// counters bundle their outer + counter contours so they render through a
// single fill path with `fill-rule="evenodd"` — that way the hole is part
// of the same shape and the letter never flashes "solid then carved".
const LETTER_GROUPS: number[][] = [
  [0],     // J
  [1],     // u
  [2],     // b
  [3, 4],  // a (outer + counter)
  [5, 6],  // y (body + stem loop)
  [7, 8],  // e (outer + counter)
  [9],     // r
];

const letterFills = LETTER_GROUPS.map((group) =>
  group.map((i) => subpaths[i]).join("")
);

const subpathToLetter = subpaths.map((_, i) =>
  LETTER_GROUPS.findIndex((g) => g.includes(i))
);
---

<svg
  class="signature"
  viewBox={VIEWBOX}
  aria-hidden="true"
  focusable="false"
>
  {/* Stroke layer — one path per contour, timed by its letter group so
      every contour belonging to a letter draws at the same time. */}
  {
    subpaths.map((d, i) => (
      <path
        class="sig-stroke"
        data-i={subpathToLetter[i]}
        pathLength={100}
        d={d}
        fill="none"
        stroke="currentColor"
        stroke-width={1.4}
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    ))
  }
  {/* Fill layer — one path per letter, fill-rule="evenodd" so a letter's
      counter contours subtract from its outer shape, leaving real holes
      from the moment the fill appears. */}
  {
    letterFills.map((d, i) => (
      <path
        class="sig-fill"
        data-i={i}
        d={d}
        fill="currentColor"
        fill-rule="evenodd"
      />
    ))
  }
</svg>

<style>
  .signature {
    /* Lock both dimensions explicitly. With width:auto the browser would
       compute width from viewBox each render — that can briefly produce a
       different value during page transitions and look like the logo
       jumps. Hard-coded width keeps the brand stable across nav. */
    height: 30px;
    width: 86px;
    color: var(--accent);
    display: inline-block;
    vertical-align: middle;
    overflow: visible;
    flex-shrink: 0;
  }
  @media (max-width: 480px) {
    .signature { height: 26px; width: 74px; }
  }

  /* Initial state — paths are invisible until the WAAPI animations run.
     If JS is disabled or before hydration, we still want the signature
     visible, so a fallback rule below reveals the fills. */
  .sig-stroke {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    opacity: 1;
  }
  .sig-fill {
    opacity: 0;
  }

  /* No-JS / pre-hydration fallback — show the filled signature so it
     renders even before the script runs. */
  html:not(.sig-ready) .sig-fill { opacity: 1; }

  @media (prefers-reduced-motion: reduce) {
    .sig-stroke { stroke-dashoffset: 0; opacity: 0; }
    .sig-fill { opacity: 1; }
  }
</style>

<script>
  const KEY = "sig-drawn-v5";
  const STAGGER_MS = 180;
  const STROKE_MS = 460;
  const STROKE_FADE_MS = 240;
  const FILL_MS = 380;
  const FILL_OFFSET_MS = 280;

  const reduced = () =>
    window.matchMedia?.("(prefers-reduced-motion: reduce)").matches ?? false;

  const totalDuration = (count: number) =>
    (count - 1) * STAGGER_MS + Math.max(STROKE_MS + STROKE_FADE_MS, FILL_OFFSET_MS + FILL_MS);

  const setRest = (sig: SVGElement) => {
    sig.querySelectorAll<SVGPathElement>(".sig-stroke").forEach((el) => {
      el.getAnimations({ subtree: false }).forEach((a) => a.cancel());
      el.style.strokeDashoffset = "0";
      el.style.opacity = "0";
    });
    sig.querySelectorAll<SVGPathElement>(".sig-fill").forEach((el) => {
      el.getAnimations({ subtree: false }).forEach((a) => a.cancel());
      el.style.opacity = "1";
    });
  };

  const play = (sig: SVGElement) => {
    if (reduced()) {
      setRest(sig);
      return;
    }
    const strokes = sig.querySelectorAll<SVGPathElement>(".sig-stroke");
    const fills = sig.querySelectorAll<SVGPathElement>(".sig-fill");

    strokes.forEach((el) => {
      const i = parseInt(el.dataset.i ?? "0", 10);
      el.getAnimations({ subtree: false }).forEach((a) => a.cancel());
      el.style.strokeDashoffset = "100";
      el.style.opacity = "1";
      el.animate(
        [
          { strokeDashoffset: "100", opacity: 1 },
          { strokeDashoffset: "0", opacity: 1, offset: STROKE_MS / (STROKE_MS + STROKE_FADE_MS) },
          { strokeDashoffset: "0", opacity: 0 },
        ],
        {
          duration: STROKE_MS + STROKE_FADE_MS,
          delay: i * STAGGER_MS,
          easing: "linear",
          fill: "forwards",
        }
      );
    });

    fills.forEach((el) => {
      const i = parseInt(el.dataset.i ?? "0", 10);
      el.getAnimations({ subtree: false }).forEach((a) => a.cancel());
      el.style.opacity = "0";
      el.animate(
        [
          { opacity: 0 },
          { opacity: 0, offset: FILL_OFFSET_MS / (FILL_OFFSET_MS + FILL_MS) },
          { opacity: 1 },
        ],
        {
          duration: FILL_OFFSET_MS + FILL_MS,
          delay: i * STAGGER_MS,
          easing: "ease-out",
          fill: "forwards",
        }
      );
    });
  };

  const apply = () => {
    document.documentElement.classList.add("sig-ready");
    let drawn = false;
    try {
      drawn = sessionStorage.getItem(KEY) === "1";
    } catch {}
    document.querySelectorAll<SVGElement>(".signature").forEach((sig) => {
      if (drawn) {
        setRest(sig);
      } else {
        play(sig);
      }
    });
    if (!drawn) {
      // Stagger is keyed to letter groups, not raw subpaths — count fills
      // (one per letter) to compute the true end time.
      const count =
        document.querySelector(".signature")?.querySelectorAll(".sig-fill")
          .length ?? 7;
      const total = totalDuration(count) + 80;
      window.setTimeout(() => {
        try {
          sessionStorage.setItem(KEY, "1");
        } catch {}
      }, total);
    }
  };

  const wireHover = () => {
    document.querySelectorAll<HTMLElement>(".brand").forEach((brand) => {
      if ((brand as any).__sigWired) return;
      (brand as any).__sigWired = true;
      brand.addEventListener("mouseenter", () => {
        const sig = brand.querySelector<SVGElement>(".signature");
        if (!sig) return;
        play(sig);
      });
    });
  };

  apply();
  wireHover();
  document.addEventListener("astro:page-load", () => {
    apply();
    wireHover();
  });
</script>
